# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5432/logistics_db"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=logistics_db
POSTGRES_PORT=5432

# Application Configuration
NODE_ENV=development
APP_PORT=3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# Development Security (개발 환경 보안)
# 프로덕션에서는 ENABLE_DEV_BYPASS=false 설정 필수
ENABLE_DEV_BYPASS=true

# PgAdmin Configuration
PGADMIN_EMAIL=admin@logistics.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# Logging
LOG_LEVEL=info

# File Upload
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=10MB

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# 카카오지도 API 설정
NEXT_PUBLIC_KAKAO_API_KEY=your-kakao-rest-api-key-here
# 카카오톡 공유 API 설정 
NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=your-kakao-javascript-key-here